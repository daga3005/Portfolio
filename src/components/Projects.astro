---
import GitHub from "./icons/GitHub.astro"
import NextJS from "./icons/NextJS.astro"
import Tailwind from "./icons/Tailwind.astro"
import Node from "./icons/Node.astro"
import ExpressJS from "./icons/Express.astro"
import Typescript from "./icons/Typescript.astro"
import ExternalLink from "./icons/ExternalLink.astro"
import LinkButton from "./LinkButton.astro"
import projectsData from "../data/projects.json"
import ChakraUi from "./icons/ChakraUi.astro"
import React from "./icons/React.astro"
import PostgreSQL from "./icons/PostgreSQL.astro"
import MySQL from "./icons/MySQL.astro"

const TAGS: Record<string, { name: string; class: string; icon: any }> = {
  NEXT: {
    name: "Next.js",
    class: "bg-gradient-to-r from-gray-800 to-gray-900 text-white border border-gray-700",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-gradient-to-r from-cyan-600 to-teal-600 text-white",
    icon: Tailwind,
  },
  TYPESCRIPT: {
    name: "Typescript",
    class: "bg-gradient-to-r from-blue-600 to-blue-700 text-white",
    icon: Typescript,
  },
  NODE: {
    name: "Node",
    class: "bg-gradient-to-r from-green-600 to-green-700 text-white",
    icon: Node,
  },
  EXPRESS: {
    name: "Express.js",
    class: "bg-gradient-to-r from-gray-700 to-gray-800 text-white",
    icon: ExpressJS,
  },
  REACT: {
    name: "React JS",
    class: "bg-gradient-to-r from-cyan-600 to-blue-600 text-white",
    icon: React,
  },
  CHAKRA: {
    name: "Chakra Ui",
    class: "bg-gradient-to-r from-teal-600 to-emerald-600 text-white",
    icon: ChakraUi,
  },
  POSTGRES: {
    name: "PostgreSQL",
    class: "bg-gradient-to-r from-sky-700 to-blue-800 text-white",
    icon: PostgreSQL,
  },
  MYSQL: {
    name: "MySQL",
    class: "bg-gradient-to-r from-orange-700 to-orange-800 text-white",
    icon: MySQL,
  }
}

const PROJECTS = projectsData.map((project) => ({
  ...project,
  tags: project.tags.map((key) => TAGS[key]),
}))
---


<div class="relative">
  {/* Línea de tiempo central */}
  <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-orange-300/50 via-orange-400/30 to-red-300/50 dark:from-orange-500/30 dark:via-orange-400/20 dark:to-red-500/30"></div>
  
  <div class="flex flex-col gap-12 sm:gap-16">
    {
      PROJECTS.map(({ title, description, tags, link, github }, index) => (
        <article class={`relative flex flex-col md:flex-row ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} gap-6 md:gap-8 group`}>
          
          {/* Marcador de tiempo */}
          <div class="absolute left-0 md:left-1/2 top-0 -translate-x-1/2 w-8 h-8 rounded-full bg-gradient-to-r from-orange-400 to-red-500 shadow-lg shadow-orange-500/30 flex items-center justify-center z-10">
            <span class="text-white text-xs font-bold">{index + 1}</span>
          </div>
          
          {/* Contenido izquierdo (fecha/ícono) */}
          <div class="hidden md:block w-1/2 pr-8 text-right">
            <div class="sticky top-32">
              <div class="inline-block p-3 rounded-2xl bg-gradient-to-br from-orange-100 to-red-100 dark:from-orange-950/30 dark:to-red-950/30">
                <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </div>
            </div>
          </div>
          
          {/* Contenido derecho */}
          <div class="flex-1 md:w-1/2 pl-8 md:pl-0">
            <div class="bg-white dark:bg-gray-900/30 rounded-2xl p-6 sm:p-8 border border-gray-100 dark:border-gray-800 hover:border-orange-200 dark:hover:border-orange-800/50 transition-all duration-300 hover:shadow-xl">
              
              <h3 class="text-2xl font-bold bg-gradient-to-r from-orange-600 to-red-600 dark:from-orange-400 dark:to-red-400 bg-clip-text text-transparent mb-2">
                {title}
              </h3>
              
              <ul class="flex flex-wrap gap-2 mb-4">
                {tags.map((tag) => (
                  <li>
                    <span class={`inline-flex items-center gap-1 rounded-full text-xs font-medium py-1 px-2.5 ${tag.class}`}>
                      <tag.icon class="size-3" />
                      {tag.name}
                    </span>
                  </li>
                ))}
              </ul>
              
              <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-5">
                {description}
              </p>
              
              <div class="flex gap-3">
                {github && (
                  <a href={github} target="_blank" class="p-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors">
                    <GitHub class="size-5" />
                  </a>
                )}
                {link && (
                  <a href={link} target="_blank" class="flex-1 text-center px-4 py-2 rounded-lg bg-gradient-to-r from-orange-500 to-red-500 text-white text-sm font-medium transition-all hover:shadow-lg hover:shadow-orange-500/25">
                    Ver proyecto →
                  </a>
                )}
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</div>