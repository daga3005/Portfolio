---
const { class: className, id, title, icon: Icon } = Astro.props
---

<section
  id={id}
  data-section={id}
  class={`section relative scroll-mt-24 md:scroll-mt-28 lg:scroll-mt-32 w-full mx-auto px-4 sm:px-6 ${className}`}
>
  <!-- Decoración de fondo sutil (opcional) -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-orange-400/5 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-red-400/5 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto lg:max-w-4xl md:max-w-2xl sm:max-w-xl">
    <!-- Título de sección (si se proporciona) -->
    {title && (
      <div class="flex items-center gap-3 mb-8 md:mb-12 lg:mb-16">
        {Icon && (
          <div class="text-orange-500 dark:text-orange-400">
            <Icon class="w-6 h-6 md:w-7 md:h-7 lg:w-8 lg:h-8" />
          </div>
        )}
        <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold bg-gradient-to-r from-orange-600 to-red-600 bg-clip-text text-transparent">
          {title}
        </h2>
        <div class="flex-1 h-px bg-gradient-to-r from-orange-200 to-transparent"></div>
      </div>
    )}
    
    <slot />
  </div>
</section>

<style is:global>
  .section {
    transition: all 0.3s ease;
  }
  
  /* Animación suave al hacer scroll */
  .section {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease forwards;
  }
  
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Diferentes delays para cada sección */
  .section:nth-child(1) { animation-delay: 0.1s; }
  .section:nth-child(2) { animation-delay: 0.2s; }
  .section:nth-child(3) { animation-delay: 0.3s; }
  .section:nth-child(4) { animation-delay: 0.4s; }
  .section:nth-child(5) { animation-delay: 0.5s; }
</style>