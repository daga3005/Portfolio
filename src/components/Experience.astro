---
import ExperienceItem from "./ExperienceItem.astro"
import experience from "../data/experience.json"
---

<div class="relative mt-8 sm:mt-12 md:mt-16">
  {/* Línea de tiempo decorativa (opcional) */}
  <div class="absolute left-[11px] sm:left-3 md:left-4 top-0 bottom-0 w-px bg-gradient-to-b from-orange-300/50 via-orange-400/30 to-red-300/50 dark:from-orange-500/30 dark:via-orange-400/20 dark:to-red-500/30"></div>
  
  <ol 
    class="relative space-y-6 sm:space-y-8 md:space-y-10 lg:space-y-12" 
    aria-label="Experiencia laboral"
  >
    {
      experience.map((exp, i) => (
        <li 
          class="anim-fade-in group" 
          style={`animation-delay: ${i * 150}ms`}
          data-index={i}
        >
          <ExperienceItem {...exp} />
        </li>
      ))
    }
  </ol>
  
  {/* Mensaje si no hay experiencia */}
  {experience.length === 0 && (
    <div class="text-center py-12">
      <p class="text-gray-500 dark:text-gray-400">Próximamente más experiencias...</p>
    </div>
  )}
</div>

<style is:global>
  .anim-fade-in {
    opacity: 0;
    animation: fadeInUp 0.5s ease forwards;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Línea de tiempo animada al hacer scroll */
  @keyframes growLine {
    from {
      transform: scaleY(0);
    }
    to {
      transform: scaleY(1);
    }
  }
  
  /* Scroll reveal para items */
  .experience-item {
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.6s ease;
  }
  
  .experience-item.revealed {
    opacity: 1;
    transform: translateX(0);
  }
</style>

<script>
  // Intersection Observer para animaciones al hacer scroll
  if (typeof window !== 'undefined') {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);
    
    // Observar cada item de experiencia
    document.querySelectorAll('.experience-item').forEach(item => {
      observer.observe(item);
    });
  }
</script>