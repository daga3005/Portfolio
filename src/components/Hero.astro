---
const personalImageAlt = "Daniel Alejandro"
import Badge from "./Badge.astro"
import CV from "./icons/CV.astro"
import GitHubIcon from "./icons/GitHub.astro"
import LinkedInIcon from "./icons/LinkedIn.astro"
import MailIcon from "./icons/Mail.astro"
import SparklesIcon from "./icons/Sparkles.astro"
import SocialPill from "./SocialPill.astro"
---

<div class="max-w-xl">
  <div class="anim-fade-in flex gap-4 mb-6 items-center">
    <!-- Avatar with ambient glow -->
    <div class="relative flex-shrink-0">
      <div
        class="absolute inset-0 rounded-full bg-yellow-400/30 dark:bg-yellow-400/20 blur-xl scale-125"
        aria-hidden="true"
      >
      </div>
      <img
        class="relative rounded-full shadow-2xl size-20 ring-2 ring-yellow-400/60 ring-offset-2 ring-offset-gray-50 dark:ring-offset-gray-950"
        src="/me.png"
        alt={personalImageAlt}
      />
    </div>
    <a
      href="https://linkedin.com/in/midudev"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge><SparklesIcon class="size-3" /> Disponible para trabajar</Badge>
    </a>
  </div>

  <h1
    class="anim-fade-in anim-delay-1 text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
  >
    Hey, soy <span class="gradient-name">Daniel Alejandro García Pérez</span>
  </h1>

  <p
    class="anim-fade-in anim-delay-2 mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300"
  >
     <strong
      >Ingeniero en Telecomunicaciones y Electrónica, full‑stack web development</strong
    > de Cienfuegos, Cuba 🇨🇺. Especializado en la creación de aplicaciones web modernas y escalables.
  </p>

  <nav
    class="anim-fade-in anim-delay-3 flex flex-wrap gap-4 mt-8"
    aria-label="Redes sociales y contacto"
  >
    <SocialPill href="/#contacto">
      <CV class="w-6 h-6 text-yellow-500"/>
      CV
    </SocialPill>
    <SocialPill href="https://linkedin.com/in/daniel-alejandro-garcía-pérez-9187a7288">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href="https://github.com/daga3005">
      <GitHubIcon class="size-4" />
      GitHub
    </SocialPill>
  </nav>
</div>