---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Welcome from "../components/Welcome.astro";
import SectionContainer from "../components/SectionContainer.astro";
import Experience from "../components/Experience.astro";
import Briefcase from "../components/icons/Briefcase.astro";
import CodeDots from "../components/icons/CodeDots.astro";
import Projects from "../components/Projects.astro";
import AboutMe from "../components/AboutMe.astro";
import UserHeart from "../components/icons/UserHeart.astro";
import Contacto from "../components/Contacto.astro";
import Contact from "../components/icons/Contact.astro";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout
	title="Portfolio de Daga - Desarrollador Full Stack en React, Next.js y TypeScript"
	description=`Contrata a Daga para tu aplicación web moderna.
 Ingeniero en Telecomunicaciones y Desarrollador Full Stack.
 Especializado en crear aplicaciones escalables con experiencia de usuario excepcional.`
>
	<SectionContainer class="py-16 md:py-36">
		<Hero />
	</SectionContainer>
	<div class="space-y-24">
		<SectionContainer id="experiencia">
			<Briefcase class="size-8" />
			Experiencia laboral

			<Experience />
		</SectionContainer>

		<SectionContainer id="proyectos">
      
        <CodeDots class="size-7" />
        Proyectos
      <Projects />
    </SectionContainer>

	<SectionContainer id="contacto">
      <Contact class="w-6 h-6 text-yellow-500"/>
        Contacto
      <Contacto />
    </SectionContainer>

	<SectionContainer id="sobre-mi">
      
        <UserHeart class="size-8" />
        Sobre mí
     
      <AboutMe />
    </SectionContainer>
	</div>
</Layout>
